<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/roomCodeTV"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Room Code: -----"
        android:textColor="#FFA500"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/roundInfoTV"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Round 1 / 5"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginTop="5dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/player_card_bg"
            android:padding="12dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/player1NameTV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Player 1"
                android:textColor="#20D6FF"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/player1ScoreTV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/player_card_bg"
            android:padding="12dp"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/player2NameTV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Player 2"
                android:textColor="#FFA500"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/player2ScoreTV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/drawsTV"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Draws: 0"
        android:textColor="#B7CEC7"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="5dp"/>

    <GridLayout
        android:id="@+id/gameBoard"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:rowCount="3"
        android:columnCount="3"
        android:layout_marginTop="15dp"/>

    <TextView
        android:id="@+id/statusTV"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Waiting for opponent..."
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:gravity="center"
        android:background="@drawable/bottom_btn_green"
        android:padding="10dp"
        android:layout_marginTop="10dp"/>

    <!-- ✅ SEULEMENT bouton Leave (sans Reset) -->
    <Button
        android:id="@+id/leaveBtn"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bottom_btn_green"
        android:text="@string/leave"
        android:textColor="#FFFFFF"
        android:textSize="14sp"/>

</LinearLayout>