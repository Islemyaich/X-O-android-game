<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Language & Mute Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="6dp">

            <Button
                android:id="@+id/btnEN"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bottom_btn_green"
                android:text="@string/en"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnFR"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bottom_btn_green"
                android:text="@string/fr"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAR"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bottom_btn_green"
                android:text="@string/ar"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnMute"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:background="@drawable/bottom_btn_green"
                android:text="🔊"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:text="@string/app_name"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:text="@string/subtitle"
            android:textColor="#CCCCCC" />

        <!-- Player card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/player_card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Player 1 header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/player1SymbolBadge"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/small_badge_blue"
                    android:gravity="center"
                    android:text="X"
                    android:textColor="#20D6FF"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/player1"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <EditText
                android:id="@+id/player1Name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_bg"
                android:gravity="center_vertical"
                android:hint="@string/player1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#8FB3A9" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/choose_symbol"
                android:textColor="#B7CEC7"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/radioX"
                    android:layout_width="58dp"
                    android:layout_height="50dp"
                    android:background="@drawable/symbol_selected_bg"
                    android:text="X"
                    android:textAllCaps="false"
                    android:textColor="#20D6FF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/radioO"
                    android:layout_width="58dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/symbol_unselected_bg"
                    android:text="O"
                    android:textAllCaps="false"
                    android:textColor="#D7E7E2"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="18dp"
                android:background="#1D7A67" />

            <!-- Player 2 header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/player2SymbolBadge"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/small_badge_orange"
                    android:gravity="center"
                    android:text="O"
                    android:textColor="#FFA500"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/player2"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <EditText
                android:id="@+id/player2Name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_bg"
                android:gravity="center_vertical"
                android:hint="@string/player2"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#8FB3A9" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✣ Auto-assigned"
                    android:textColor="#9CB8B0"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/autoAssignedSymbol"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/small_badge_orange"
                    android:gravity="center"
                    android:text="O"
                    android:textColor="#FFA500"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- AI card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:background="@drawable/bottom_btn_green"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/play_vs_ai"
                android:textColor="#FFFFFF" />

            <Switch
                android:id="@+id/switchAI"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Difficulty -->
        <LinearLayout
            android:id="@+id/difficultyLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/easyBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/option_unselected_green_bg"
                android:backgroundTint="@null"
                android:text="@string/easy"
                android:textColor="#D7E7E2"/>

            <Button
                android:id="@+id/mediumBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/option_unselected_green_bg"
                android:backgroundTint="@null"
                android:text="@string/medium"
                android:textColor="#D7E7E2"/>

            <Button
                android:id="@+id/hardBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/option_unselected_green_bg"
                android:backgroundTint="@null"
                android:text="@string/hard"
                android:textColor="#D7E7E2"/>

        </LinearLayout>

        <!-- Rounds -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:background="@drawable/bottom_btn_green"
            android:orientation="horizontal"
            android:padding="16dp">

            <Button
                android:id="@+id/round5"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/round_unselected_green"
                android:backgroundTint="@null"
                android:text="5"
                android:textColor="#D7E7E2"/>

            <Button
                android:id="@+id/round10"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/round_unselected_green"
                android:backgroundTint="@null"
                android:text="10"
                android:textColor="#D7E7E2"/>

            <Button
                android:id="@+id/round15"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/round_unselected_green"
                android:backgroundTint="@null"
                android:text="15"
                android:textColor="#D7E7E2"/>

        </LinearLayout>

        <!-- Play -->
        <Button
            android:id="@+id/btnPlay"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/play_btn_bg"
            android:backgroundTint="@null"
            android:text="@string/play"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>

        <!-- ONLINE BUTTON -->
        <Button
            android:id="@+id/btnOnline"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/play_btn_bg"
            android:text="@string/online"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>

        <!-- Bottom buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnRules"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:background="@drawable/bottom_btn_green"
                android:backgroundTint="@null"
                android:text="@string/rules"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btnScores"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bottom_btn_green"
                android:backgroundTint="@null"
                android:text="@string/scores"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>