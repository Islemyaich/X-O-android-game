<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape>
            <solid android:color="@color/orange_glow"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>

    <item android:inset="2dp">
        <shape>
            <solid android:color="@color/orange_fill_soft"/>
            <corners android:radius="12dp"/>
            <stroke
                android:width="2dp"
                android:color="@color/orange_main"/>
        </shape>
    </item>

</layer-list>